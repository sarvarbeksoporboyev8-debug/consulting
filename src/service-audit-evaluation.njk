---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/service-audit-evaluation.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/service-audit-evaluation.css",
  navKey: "Services",
  extraFonts: "&family=Merriweather:wght@700",
  currentPage: "service-audit-evaluation.html",
  serviceIdx: 5,
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.serviceDetails[5][L] || data.serviceDetails[5].en).title; },
    description: function(data) { var L = data.lang.code; return (data.serviceDetails[5][L] || data.serviceDetails[5].en).description; },
    heroTitle: function(data) { var L = data.lang.code; return (data.serviceDetails[5][L] || data.serviceDetails[5].en).heroTitle; },
    breadcrumbs: function(data) {
      var L = data.lang.code;
      return [
        { label: (data.ui[L]||data.ui.en).page_services_hero, url: "services.html" },
        { label: (data.serviceDetails[5][L] || data.serviceDetails[5].en).breadcrumbLabel }
      ];
    }
  }
}
---
{% include "partials/service-detail-content.njk" %}
