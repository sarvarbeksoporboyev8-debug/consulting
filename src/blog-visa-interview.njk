---js
{
  pagination: { data: "languages", size: 1, alias: "lang" },
  permalink: function(data) { return data.lang.code + "/blog-visa-interview.html"; },
  layout: "layouts/page.njk",
  pageCss: "css/blog-post.css",
  navKey: "Blog",
  extraFonts: "&family=Merriweather:wght@700",
  currentPage: "blog-visa-interview.html",
  postIdx: 3,
  eleventyComputed: {
    title: function(data) { var L = data.lang.code; return (data.blogPosts[3][L] || data.blogPosts[3].en).title + " - Grant Consulting"; },
    description: function(data) { var L = data.lang.code; return (data.blogPosts[3][L] || data.blogPosts[3].en).excerpt; },
    heroTitle: function(data) { var L = data.lang.code; return (data.blogPosts[3][L] || data.blogPosts[3].en).title; },
    breadcrumbs: function(data) {
      var L = data.lang.code;
      return [
        { label: (data.ui[L]||data.ui.en).page_blog_hero, url: "blog.html" },
        { label: (data.blogPosts[3][L] || data.blogPosts[3].en).title }
      ];
    }
  }
}
---
{% include "partials/blog-post-content.njk" %}
