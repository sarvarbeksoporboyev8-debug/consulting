    <section class="form-faq">
      <div>
        <h2>Ready to start your journey?</h2>
        <p class="subtitle">Get a free consultation</p>
        <form class="stacked-form" action="https://formspree.io/f/{YOUR_FORM_ID}" method="POST" data-form novalidate>
          <div class="field-group">
            <label for="{{ formPrefix }}-name">Your Name*</label>
            <input type="text" id="{{ formPrefix }}-name" name="name" placeholder="Your name" required>
          </div>
          <div class="field-group">
            <label for="{{ formPrefix }}-email">Your Email*</label>
            <input type="email" id="{{ formPrefix }}-email" name="email" placeholder="name@example.com" required>
          </div>
          <div class="field-group">
            <label for="{{ formPrefix }}-query">How can we help?*</label>
            <textarea id="{{ formPrefix }}-query" name="message" placeholder="Which country and program are you interested in? What is your IELTS score?" required></textarea>
          </div>
          <button type="submit" class="btn-primary">Send a Message</button>
          <p class="form-status" data-form-status aria-live="polite"></p>
        </form>
      </div>
      <div>
        {% include "partials/faq-details.njk" %}
      </div>
    </section>
